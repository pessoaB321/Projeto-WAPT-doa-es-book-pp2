<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administradores</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px;background-color:#d8bb8f; }

        .card { border: 1px solid #000000; padding: 16px; border-radius: 8px; margin-bottom: 16px; background-color: #f9f9f9; box-shadow: 4px 8px 20px 5px rgb(96, 69, 36); }

        .card-info {
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
        }

        .card-texto {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .card-header {
            display: flex;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
            width: 100%;
        }

        .details {
            margin-top: 10px;
            font-size: 14px;
            color: #5c3a1f;
            display: none;
            padding: 10px;
            border-left: 4px solid #743513;
            background-color: #f3e3ce;
            border-radius: 6px;
        }

        .details.show {
            display: block;
        }

        .toggle-details {
            background: #8b571c;
            color: white;
            border: none;
            padding: 6px 10px;
            border-radius: 4px;
            cursor: pointer;
            margin-top: 8px;
        }

        .search-box {
            background-color: #743513;
            padding: 16px;
            border-radius: 8px;
            margin: 16px 0 20px;
            box-shadow: 2px 4px 12px rgba(0, 0, 0, 0.2);
        }

        .search-box input {
            width: 280px;
            border: none;
            border-radius: 4px;
        }

        .reset-link {
            display: inline-block;
            margin-left: 8px;
            padding: 8px 10px;
            background-color: #ffffff;
            color: #743513;
            border-radius: 4px;
            text-decoration: none;
            font-weight: bold;
        }

        a, button { display: inline-block; margin-bottom: 16px; text-decoration: none; color: #8b571c; }

        form.inline { display: inline; }

        input { padding: 8px; margin-right: 8px; width: 70%; }

        button { padding: 8px 10px; cursor: pointer; background: #8b571c; color: white; border: none; border-radius: 4px; }

        .delete-btn {
            
            background:#743513 ;
        }

        .foto-admin {
            width: 90px;
            height: 90px;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid #8b571c;
            margin-top: 8px;
            margin-bottom: 8px;
            background-color: #e8d7bf;
        }
        
    </style>
</head>
<body>
    <a href="/" style="display:inline-block; margin-bottom:16px; text-decoration:none; color:#743513; font-weight:bold;">← Voltar para Home</a>
    <h1>Administradores</h1>
    <a href="/admin/novo">Cadastrar novo administrador</a>

    <div class="search-box">
        <form method="GET" action="/admin">
            <input type="text" name="busca" placeholder="Buscar por nome ou e-mail" value="{{termo}}">
            <button type="submit">Procurar</button>
            {{#if termo}}
                <a class="reset-link" href="/admin">Limpar</a>
            {{/if}}
        </form>
    </div>

    {{#if administradores.length}}
        {{#each administradores}}
            <div class="card">
                <div class="card-info">
                    <div class="card-header">
                        {{#if foto}}
                            <img class="foto-admin" src="{{foto}}" alt="Foto de {{nome}}" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';">
                            <span style="display:none; color:#8b1f1f;">Foto indisponível no momento.</span>
                        {{/if}}
                        <div class="card-texto">
                            <strong>{{nome}}</strong>
                            <span>Cargo: {{cargo}}</span>
                        </div>
                    </div>
                    <div class="details" id="details-{{id}}">
                        <strong>Email:</strong> {{email}}<br>
                        <strong>ID:</strong> {{id}}<br>
                        <strong>Status:</strong> {{status}}<br>
                        {{#if foto}}
                            
                        {{else}}
                            <strong>Foto:</strong> Nenhuma foto cadastrada
                        {{/if}}
                    </div>
                </div>
                <button class="toggle-details" type="button" onclick="toggleDetails('details-{{id}}', this)">Ver mais detalhes</button>
                <a href="/admin/editar/{{id}}">Editar</a>
                <form class="inline" action="/admin/delete" method="POST" onsubmit="return confirm('Tem certeza que deseja excluir este administrador?');">
                    <input type="hidden" name="id" value="{{id}}">
                    <button class="delete-btn" type="submit">Excluir</button>
                </form>
            </div>
        {{/each}}
    {{else}}
        <p>Nenhum administrador encontrado.</p>
    {{/if}}

    <script>
        function toggleDetails(id, button) {
            const details = document.getElementById(id);
            if (details) {
                details.classList.toggle('show');
                if (button) {
                    button.textContent = details.classList.contains('show') ? 'Mostrar menos' : 'Ver mais detalhes';
                }
            }
        }
    </script>
</body>
</html>