<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Cadastro de Doações</title>
    <!-- Vincula o CSS que criamos -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <h2>Cadastrar Livro para Doação</h2>
        
        <!-- Formulário de Cadastro -->
        <form action="/doar/add" method="POST">
            <div class="form-group">
                <label>Título do Livro:</label>
                <input type="text" name="titulo" required placeholder="Ex: O Alquimista">
            </div>
            <div class="form-group">
                <label>Autor:</label>
                <input type="text" name="autor" required placeholder="Ex: Paulo Coelho">
            </div>
            <div class="form-group">
                <label>Estado de Conservação:</label>
                <select name="estadoConservacao" required>
                    <option value="Novo">Novo</option>
                    <option value="Muito Bom">Muito Bom</option>
                    <option value="Usado">Usado / Marcas de Uso</option>
                </select>
            </div>
            <button type="submit" class="btn-submit">Cadastrar Doação</button>
        </form>

        <hr style="margin: 30px 0; border: 0; border-top: 1px solid #e2e8f0;">

                <h2>Livros Disponíveis</h2>
        <!-- Listagem dos livros salvos -->
        {{#each livros}}
            <div class="card-livro">
                <h3>📖 {{this.titulo}}</h3>
                <p><strong>Autor:</strong> {{this.autor}}</p>
                <p><strong>Estado:</strong> {{this.estadoConservacao}}</p>
                
                <!-- Botão de Vínculo que sua colega pediu -->
                <button class="btn-vincular" onclick="alert('Este livro foi reservado e vinculado ao seu perfil com sucesso!')">
                    👤 Vincular ao meu Perfil
                </button>
            </div>
        {{else}}
            <!-- Mensagem amigável caso o banco de dados esteja zerado -->
            <p style="color: #718096; italic; text-align: center; margin-top: 20px;">
                Nenhum livro cadastrado para doação no momento. Use o formulário acima para registrar o primeiro!
            </p>
        {{/each}}

