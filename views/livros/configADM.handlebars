<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuração de Administrador</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; background-color:#d8bb8f; }

        .container {
            max-width: 380px;
            margin: 0 auto;
            padding: 24px;
            border: 1px solid #000000;
            border-radius: 10px;
            background-color: #b07b4d;
            box-shadow: 4px 8px 20px 5px rgb(96, 69, 36);
        }

        .erro {
            background-color: #fff3f3;
            color: #8b1f1f;
            border: 1px solid #d98c8c;
            padding: 10px;
            border-radius: 6px;
            margin-bottom: 12px;
            font-size: 14px;
        }

        form {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        input, select { padding: 8px; }

        button, a { display: inline-block; margin-bottom: 16px; text-decoration: none; color: #8b571c; }

        button {
            padding: 8px 10px;
            cursor: pointer;
            background: #8b571c;
            color: white;
            border: none;
            border-radius: 4px;
        }
    </style>
</head>
<body>
    <div class="container">
        {{#if erro}}
            <div class="erro">{{erro}}</div>
        {{/if}}

        {{#if editando}}
            <h1>Editar Administrador</h1>
            <form action="/admin/editar/{{administrador.id}}" method="POST">
                <input type="text" name="nome" placeholder="Nome" value="{{administrador.nome}}" required>
                <input type="email" name="email" placeholder="E-mail" value="{{administrador.email}}" required>
                <input type="password" name="senha" placeholder="Senha" value="{{administrador.senha}}" required>
                <select name="cargo">
                    <option value="Administrador Mestre" {{#if (eq administrador.cargo "Administrador Mestre")}}selected{{/if}}>Administrador Mestre</option>
                    <option value="Bibliotecário" {{#if (eq administrador.cargo "Bibliotecário")}}selected{{/if}}>Bibliotecário</option>
                    <option value="Funcionário do IFPE" {{#if (eq administrador.cargo "Funcionário do IFPE")}}selected{{/if}}>Funcionário do IFPE</option>
                </select>
                <select name="status">
                    <option value="Ativo" {{#if (eq administrador.status "Ativo")}}selected{{/if}}>Ativo</option>
                    <option value="Desligado" {{#if (eq administrador.status "Desligado")}}selected{{/if}}>Desligado</option>
                </select>
                <input type="url" name="foto" placeholder="URL da foto (opcional)" value="{{administrador.foto}}">
                <button type="submit">Atualizar</button>
            </form>
        {{else}}
            <h1>Cadastrar Administrador</h1>
            <form action="/admin/novo" method="POST">
                <input type="text" name="nome" placeholder="Nome" required>
                <input type="email" name="email" placeholder="E-mail" required>
                <input type="password" name="senha" placeholder="Senha" required>
                <select name="cargo">
                    <option value="Administrador Mestre">Administrador Mestre</option>
                    <option value="Bibliotecário">Bibliotecário</option>
                    <option value="Funcionário do IFPE">Funcionário do IFPE</option>
                </select>
                <select name="status">
                    <option value="Ativo">Ativo</option>
                    <option value="Desligado">Desligado</option>
                </select>
                <input type="url" name="foto" placeholder="URL da foto (opcional)">
                <button type="submit">Salvar</button>
            </form>
        {{/if}}
        <p><a href="/admin">Voltar para a lista</a></p>
    </div>
</body>
</html>